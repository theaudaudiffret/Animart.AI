# Backend (FastAPI) — copier en .env (git-ignoré). Ne jamais committer les secrets.

# Clés IA
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=            # optionnel, défaut Charlotte (multilingue)

# Supabase
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=        # SECRET — backend uniquement, jamais côté front
# SUPABASE_JWT_SECRET=            # uniquement si le projet utilise le secret JWT HS256 « legacy »

# Réglages prod / scalabilité
ALLOWED_ORIGINS=*                 # ex: https://animart.example.com,https://www.animart.example.com
MAX_SCANS_PER_DAY=200             # cap quotidien de scans par utilisateur (0 = illimité)
MAX_CONCURRENT_IMMERSIVE=4        # générations immersives simultanées par worker
WEB_CONCURRENCY=4                 # workers gunicorn (prod)
# THREAD_LIMIT=200                # appels IO (Claude/ElevenLabs) en vol par worker
